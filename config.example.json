{
  "version": "0.9",
  "servers": [
    {
      "alias": "s1",
      "host": "__your_host__",
      "user": "__your_user__",
      "port": 22,
      "container": "__your_container__",
      "desc": "主开发服务器"
    }
  ],
  "default_server": "s1",
  "workspaces": {
    "task_root": "/home/__your_user__/Tasks",
    "weights_root": "/home/__your_user__/weights",
    "code_root": "/home/__your_user__/Code"
  },
  "restrictions": {
    "forbidden_commands": [
      "sudo rm -rf /",
      "reboot",
      "shutdown",
      "init 0",
      "init 6"
    ],
    "confirm_required": [
      "rm -rf",
      "docker rm",
      "docker rmi",
      "kill -9"
    ]
  }
}
